{
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://obrascan-backend-v3.onrender.com/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://obrascan-backend-v3.onrender.com/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
